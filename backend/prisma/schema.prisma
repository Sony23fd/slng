generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model constant {
  id          Int      @id @default(autoincrement())
  type        String
  value       String
  description String?
  createdAt   DateTime @default(now())
}

model customer {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  phone           String?
  email           String?
  company_name    String?
  discount_margin Int?     @default(20)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model masterprice {
  id             Int                  @id @default(autoincrement())
  category       String
  item_name      String
  unit_cost      Float
  formula_id     Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  masterpricelog masterpricelog[]
  formula        calculation_formula? @relation(fields: [formula_id], references: [id])
}

model masterpricelog {
  id            Int         @id @default(autoincrement())
  masterPriceId Int
  changed_by    Int
  old_cost      Float
  new_cost      Float
  createdAt     DateTime    @default(now())
  user          user        @relation(fields: [changed_by], references: [id])
  masterprice   masterprice @relation(fields: [masterPriceId], references: [id], onDelete: Cascade)

  @@index([changed_by])
  @@index([masterPriceId])
}

model order {
  id                Int                 @id @default(autoincrement())
  customer_name     String
  phone             String?
  deadline          DateTime?
  product_name      String
  category          String?
  binding_type      String?
  total_qty         Int
  size              String?
  sub_size          String?
  needs_design      Boolean             @default(false)
  is_urgent         Boolean             @default(false)
  sales_person_name String?
  sales_person_id   Int?
  notes             String?
  profit_margin     Float               @default(0)
  has_vat           Boolean             @default(false)
  final_price       Float               @default(0)
  payment_method_1  String?
  payment_percent_1 Float?
  payment_method_2  String?
  payment_percent_2 Float?
  finance_notes     String?
  current_status    String              @default("Хүлээгдэж буй")
  production_stages Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  order_number      String?             @unique
  user              user?               @relation(fields: [sales_person_id], references: [id])
  materials         ordermaterial[]
  operations        orderoperation[]
  outsourcedJobs    orderoutsourced[]
  specifications    orderspecification?
  orderstatuslog    orderstatuslog[]

  @@index([sales_person_id])
}

model ordermaterial {
  id            Int     @id @default(autoincrement())
  order_id      Int
  material_name String
  size          String?
  print_size    String?
  press_sheet   String?
  base_qty      Int?
  extra_qty     Int?
  is_cover      Boolean @default(false)
  total_qty     Int
  divide_by     Int     @default(1)
  unit_cost     Float
  total_cost    Float
  notes         String?
  sheet_qty     Float?
  order         order   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
}

model orderoperation {
  id             Int     @id @default(autoincrement())
  order_id       Int
  operation_name String
  qty            Int
  unit_cost      Float
  total_cost     Float
  notes          String?
  order          order   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
}

model orderoutsourced {
  id         Int     @id @default(autoincrement())
  order_id   Int
  job_name   String
  qty        Int
  unit_cost  Float
  total_cost Float
  notes      String?
  order      order   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
}

model orderspecification {
  id           Int     @id @default(autoincrement())
  order_id     Int     @unique
  cover_color  String?
  inner_color  String?
  has_bookmark String?
  total_pages  Int?
  print_cost   Float?  @default(0)
  order        order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model orderstatuslog {
  id         Int      @id @default(autoincrement())
  order_id   Int
  changed_by Int
  old_status String
  new_status String
  notes      String?
  createdAt  DateTime @default(now())
  user       user     @relation(fields: [changed_by], references: [id])
  order      order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([changed_by])
  @@index([order_id])
}

model producttemplate {
  id            Int      @id @default(autoincrement())
  template_name String   @unique
  category      String?
  binding_type  String?
  size          String?
  cover_color   String?
  inner_color   String?
  total_pages   Int?
  needs_design  Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model user {
  id             Int              @id @default(autoincrement())
  name           String
  role           user_role        @default(SALES)
  password       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stamp_url      String?
  phone          String?
  masterpricelog masterpricelog[]
  order          order[]
  orderstatuslog orderstatuslog[]
}

enum user_role {
  ADMIN
  FINANCE
  SALES
  PRODUCTION
}

model coverrule {
  id          Int      @id @default(autoincrement())
  size        String
  binding     String
  press_sheet Float
  divide_by   Int
  print_size  String

  @@unique([size, binding])
}

model product_category {
  id             Int     @id @default(autoincrement())
  name           String  @unique
  calc_mode      String
  has_cover      Boolean @default(true)
  has_inner      Boolean @default(true)
  has_binding    Boolean @default(true)
  has_pages      Boolean @default(true)
  has_bookmark   Boolean @default(false)
  waste_qty      Int     @default(0)
}

model calculation_formula {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  expression  String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  masterprices masterprice[]
}
